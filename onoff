#!/usr/bin/env perl
# A perl script to start on a given regexp and stop on another
# or a given line number and ending on another

use strict;
use warnings;

use Data::Dumper;
use File::Basename qw(basename dirname);
use File::Path qw(make_path);
use File::Spec;
use File::Temp qw(tempfile);
use Text::Abbrev;

my $last_mod_date='Thu, Jul 23, 2026';

my $version="1.3";

my $author="Dr. Steven Parker";
my $copyright="$last_mod_date. All rights reserved.";

my $name = $0; $name =~ s'.*/''; # remove path--like basename
my $usage  = "usage:\n$name\n\t";
$usage .= "[ ( -?      | --help  | --debug | --usage ) ]\n\t";
$usage .= "[ ( --on | --begin | --start | --start-after ) start_regexp ]\n\t";
$usage .= "[ ( --off | --end | --stop | --end-before ) stop_regexp ]\n\t";
$usage .= "[ ( --regexp | --find | --grep ) regexp ]\n\t";
$usage .= "[ --exclude-start ] [ --exclude-end ]\n\t";
$usage .= "[ --fixed ] [ --ignore-case ] [ --list-ranges ]\n\t";
$usage .= "[ --interactive [ --responses FILE ] ]\n\t";
$usage .= "[ --output FILE | --output-template TEMPLATE ] [ --output-dir DIR ]\n\t";
$usage .= "[ --append | --force ] [ --otherwise FILE ]\n\t";
$usage .= "[ --lead N --linger M | --context N ]\n\t";
$usage .= "[  N..M     |  N..   |  ..M  |  N  ]\n\t";
$usage .= "[ --number ]\n\t";
$usage .= "[ [ --file ] file1 file2 .. ]";

my $plan = initialize_plan();

parse_arguments($plan, @ARGV);
validate_plan($plan);
push @{$plan->{files}}, '-' unless @{$plan->{files}};
print Dumper($plan) if ($plan->{debug});
my $stats = execute_plan($plan);

exit 2 if $stats->{errors};
exit(
  $plan->{list_ranges}
    ? (@{$stats->{ranges}} ? 0 : 1)
    : ($stats->{lines_selected} ? 0 : 1)
);

sub initialize_plan {
  return {
    debug          => 0,
    append         => 0,
    end_patterns   => [],
    explanations   => [],
    files          => [],
    fixed           => 0,
    force           => 0,
    ignore_case     => 0,
    interactive     => 0,
    include_end     => 1,
    include_start   => 1,
    lead           => 0,
    linger         => 0,
    list_ranges    => 0,
    match_patterns => [],
    print_stops    => 1,
    on_duplicate   => 'error',
    otherwise      => undef,
    output_dir     => '.',
    output_dir_set => 0,
    output_dynamic => 0,
    output_template => undef,
    responses       => undef,
    ranges         => [],
    end_pattern_policies   => {},
    rules          => [],
    start_patterns => [],
    start_pattern_policies => {},
    start_lines    => {},
    start_printing => 0,
    stop_lines     => {},
  };
}

sub execute_plan {
  my $plan = shift;
  my $stats = {
    ends_matched        => 0,
    errors              => 0,
    files_processed     => 0,
    lines_printed       => 0,
    lines_read          => 0,
    lines_selected      => 0,
    lines_skipped       => 0,
    matches_by_rule     => {},
    ranges              => [],
    ranges_completed    => 0,
    ranges_unterminated => 0,
    ranges_started      => 0,
    starts_matched      => 0,
    output_files        => 0,
  };
  my $output_manager = initialize_output_manager($plan, $stats);
  my $review = initialize_interactive_review($plan, $stats);
  if ($review->{failed}) {
    finalize_output_manager($plan, $output_manager, $stats);
    return $stats;
  }

  FILE:
  foreach my $file (@{$plan->{files}}) {
    $output_manager->{current_file} = $file;
    my ($initial_rule) = grep { $_->{start_at_beginning} } @{$plan->{rules}};
    my $state = {
      active_range_start => $initial_rule
        ? ($initial_rule->{include_start} ? 1 : 2)
        : undef,
      active_rule        => $initial_rule,
      filename           => $file,
      lead_buffer        => [],
      line_number        => 0,
      linger_left        => 0,
      output_sink        => undef,
      captures           => empty_captures(),
      rejected_rule      => undef,
      review_context     => [],
    };

    my $filehandle;
    if ($file eq '-') {
      if (!open($filehandle, '<-')) {
        warn "Cannot read from STDIN: $!\n";
        $stats->{errors}++;
        next;
      }
    } else {
      if (!open($filehandle, '<', $file)) {
        warn "Cannot read from '$file': $!\n";
        $stats->{errors}++;
        next;
      }
    }
    $stats->{files_processed}++;

    while (my $line = <$filehandle>) {
      $state->{line_number}++;
      $stats->{lines_read}++;

      if ($state->{rejected_rule}) {
        my $rejected_end = rule_end_matches(
          $state->{rejected_rule},
          $line,
          $state->{line_number},
        );
        reject_line($plan, $output_manager, $stats, $state, $line);
        $state->{rejected_rule} = undef if $rejected_end;
        next;
      }

      my $was_active = $state->{active_rule};
      my $rule = $was_active;
      my $start_captures;
      my $implicit_start_event =
        $was_active
        && $was_active->{start_at_beginning}
        && $state->{line_number} == 1;
      my $start_event = $implicit_start_event;
      $start_captures = empty_captures() if $implicit_start_event;

      if (!$rule) {
        for my $candidate (@{$plan->{rules}}) {
          my $captures = match_rule_start(
            $candidate,
            $line,
            $state->{line_number},
          );
          if ($captures) {
            $rule = $candidate;
            $start_event = 1;
            $start_captures = $captures;
            last;
          }
        }
      }

      if ($start_event && $plan->{interactive} && !$review->{accept_all}) {
        my $answer = review_candidate(
          $review,
          $file,
          $state->{line_number},
          $line,
          $state->{review_context},
          $rule->{name},
        );
        if ($answer eq 'quit') {
          $review->{quit} = 1;
          discard_lead_buffer($plan, $output_manager, $stats, $state);
          reject_line($plan, $output_manager, $stats, $state, $line);
          last;
        }
        if ($answer eq 'no') {
          $state->{active_rule} = undef;
          $state->{active_range_start} = undef;
          $state->{rejected_rule} = $rule;
          discard_lead_buffer($plan, $output_manager, $stats, $state);
          reject_line($plan, $output_manager, $stats, $state, $line);
          $state->{rejected_rule} = undef
            if rule_end_matches($rule, $line, $state->{line_number});
          next;
        }
        $review->{accept_all} = 1 if $answer eq 'all';
      }

      my $end_match =
        $rule && rule_end_matches($rule, $line, $state->{line_number});
      my $single_captures = match_regexp($plan->{regexp}, $line);
      my $single_match = defined $single_captures;
      my $active_end = $rule && $end_match;
      my $within_linger = $state->{linger_left} > 0;
      my $start_boundary_excluded =
        $start_event && !$rule->{include_start};
      my $end_boundary_excluded =
        $active_end && !$rule->{include_end};
      my $boundary_included =
        ($start_event && $rule->{include_start})
        || ($active_end && $rule->{include_end});
      my $range_interior =
        $was_active
        && !$start_boundary_excluded
        && !$end_boundary_excluded;
      my $context_selected =
        $within_linger
        && !$start_boundary_excluded
        && !$end_boundary_excluded;
      my $line_selected =
        $range_interior
        || $boundary_included
        || $single_match
        || $context_selected;

      if ($start_event) {
        $stats->{starts_matched}++;
        $stats->{matches_by_rule}{$rule->{name}}++;
        $stats->{ranges_started}++;
        $state->{captures} = $start_captures || empty_captures();
        if (!$plan->{list_ranges}) {
          $state->{output_sink} = output_sink_for_selection(
            $plan,
            $output_manager,
            $stats,
            $rule,
            $state,
            $stats->{ranges_started},
          );
        }
      }
      $stats->{ends_matched}++ if $active_end;

      if ($start_event && !$implicit_start_event) {
        $state->{active_range_start} =
          $state->{line_number} + ($rule->{include_start} ? 0 : 1);
      }

      if ($single_match && !$plan->{has_range_conditions}) {
        $stats->{ranges_started}++;
        $state->{captures} = $single_captures;
        if (!$plan->{list_ranges}) {
          $state->{output_sink} = output_sink_for_selection(
            $plan,
            $output_manager,
            $stats,
            $plan,
            $state,
            $stats->{ranges_started},
            'match',
          );
        }
        record_range(
          $stats,
          $file,
          $state->{line_number},
          $state->{line_number},
          'match',
        );
      }

      if ($start_event || $single_match) {
        while (@{$state->{lead_buffer}}) {
          my $buffered = shift @{$state->{lead_buffer}};
          print_line(
            $plan,
            $state,
            $stats,
            $buffered->{text},
            $buffered->{number},
          );
        }
      }

      if ($line_selected) {
        print_line($plan, $state, $stats, $line);
      } else {
        if ($start_boundary_excluded || $end_boundary_excluded) {
          $stats->{lines_skipped}++;
          write_otherwise(
            $plan,
            $output_manager,
            $stats,
            $line,
          );
        } elsif ($plan->{lead}) {
          push @{$state->{lead_buffer}}, {
            number => $state->{line_number},
            text   => $line,
          };
          if (@{$state->{lead_buffer}} > $plan->{lead}) {
            my $discarded = shift @{$state->{lead_buffer}};
            $stats->{lines_skipped}++;
            write_otherwise(
              $plan,
              $output_manager,
              $stats,
              $discarded->{text},
            );
          }
        } else {
          $stats->{lines_skipped}++;
          write_otherwise(
            $plan,
            $output_manager,
            $stats,
            $line,
          );
        }
      }

      if ($active_end) {
        my ($selected_start, $selected_end);
        if ($start_event) {
          if ($rule->{include_start} || $rule->{include_end}) {
            $selected_start = $state->{line_number};
            $selected_end = $state->{line_number};
          }
        } else {
          $selected_start = $state->{active_range_start};
          $selected_end =
            $state->{line_number} - ($rule->{include_end} ? 0 : 1);
        }
        record_range(
          $stats,
          $file,
          $selected_start,
          $selected_end,
          $rule->{name},
        );
        $stats->{ranges_completed}++;
        $state->{active_range_start} = undef;
        $state->{active_rule} = undef;
      } elsif ($rule) {
        $state->{active_rule} = $rule;
      }

      $state->{linger_left}-- if $within_linger;
      if ($single_match || $active_end) {
        $state->{linger_left} = $plan->{linger}
          if $plan->{linger} > $state->{linger_left};
      }
      if (!$state->{active_rule} && !$state->{linger_left}) {
        $state->{output_sink} = undef;
      }
      remember_review_context($state, $line);
    }

    if ($state->{active_rule}
        && $state->{line_number}
        && $state->{active_range_start} <= $state->{line_number}) {
      record_range(
        $stats,
        $file,
        $state->{active_range_start},
        'EOF',
        $state->{active_rule}{name},
      );
      $stats->{ranges_unterminated}++;
    }

    $stats->{lines_skipped} += @{$state->{lead_buffer}};
    for my $buffered (@{$state->{lead_buffer}}) {
      write_otherwise(
        $plan,
        $output_manager,
        $stats,
        $buffered->{text},
      );
    }
    if (!close($filehandle)) {
      warn "Cannot close '$file': $!\n";
      $stats->{errors}++;
    }
    last FILE if $review->{quit};
  }

  close_interactive_review($review, $stats);
  finalize_output_manager($plan, $output_manager, $stats);

  if ($plan->{list_ranges}) {
    for my $range (@{$stats->{ranges}}) {
      my $filename = $range->{file} eq '-' ? '<stdin>' : $range->{file};
      print join(
        "\t",
        $filename,
        $range->{start},
        $range->{end},
        $range->{rule},
      ), "\n";
    }
  }

  return $stats;
}

sub initialize_interactive_review {
  my ($plan, $stats) = @_;
  return { enabled => 0 } unless $plan->{interactive};

  my ($input, $output, $close_input);
  if (defined $plan->{responses}) {
    if (!open($input, '<', $plan->{responses})) {
      runtime_error($stats, "cannot read responses '$plan->{responses}': $!");
      return { enabled => 0, failed => 1 };
    }
    $output = \*STDERR;
    $close_input = 1;
  } else {
    if (!open($input, '+<', '/dev/tty')) {
      runtime_error(
        $stats,
        'interactive mode requires a terminal or --responses FILE',
      );
      return { enabled => 0, failed => 1 };
    }
    $output = $input;
    $close_input = 1;
  }

  return {
    accept_all  => 0,
    close_input => $close_input,
    enabled     => 1,
    input       => $input,
    output      => $output,
    quit        => 0,
  };
}

sub close_interactive_review {
  my ($review, $stats) = @_;
  return unless $review->{close_input} && $review->{input};
  runtime_error($stats, "cannot close interactive response input: $!")
    unless close($review->{input});
}

sub review_candidate {
  my ($review, $file, $line_number, $line, $context, $rule_name) = @_;
  return 'yes' unless $review->{enabled};
  my $display_file = $file eq '-' ? '<stdin>' : $file;
  my $output = $review->{output};

  print {$output} "\nCandidate range: $display_file:$line_number";
  print {$output} " (rule $rule_name)" if defined $rule_name;
  print {$output} "\n";
  for my $previous (@{$context}) {
    printf {$output} "  %5d | %s", $previous->{number}, $previous->{text};
  }
  printf {$output} "> %5d | %s", $line_number, $line;

  while (1) {
    print {$output} "Start printing? [y]es, [n]o, [a]ll, [q]uit: ";
    my $response = readline($review->{input});
    if (!defined $response) {
      print {$output} "\n";
      return 'quit';
    }
    $response =~ s/^\s+|\s+$//g;
    my %answers = (
      a => 'all', all => 'all',
      n => 'no', no => 'no',
      q => 'quit', quit => 'quit',
      y => 'yes', yes => 'yes',
    );
    if (exists $answers{lc $response}) {
      print {$output} "\n" unless $response =~ /\n$/;
      return $answers{lc $response};
    }
    print {$output} "Please answer yes, no, all, or quit.\n";
  }
}

sub remember_review_context {
  my ($state, $line) = @_;
  push @{$state->{review_context}}, {
    number => $state->{line_number},
    text   => $line,
  };
  shift @{$state->{review_context}} while @{$state->{review_context}} > 2;
}

sub reject_line {
  my ($plan, $output_manager, $stats, $state, $line) = @_;
  $stats->{lines_skipped}++;
  write_otherwise($plan, $output_manager, $stats, $line);
  remember_review_context($state, $line);
}

sub discard_lead_buffer {
  my ($plan, $output_manager, $stats, $state) = @_;
  for my $buffered (@{$state->{lead_buffer}}) {
    $stats->{lines_skipped}++;
    write_otherwise($plan, $output_manager, $stats, $buffered->{text});
  }
  $state->{lead_buffer} = [];
}

sub match_rule_start {
  my ($rule, $line, $line_number) = @_;
  return empty_captures()
    if $rule->{start_lines} && $rule->{start_lines}{$line_number};
  return match_regexp($rule->{start_regexp}, $line);
}

sub rule_end_matches {
  my ($rule, $line, $line_number) = @_;
  return
    ($rule->{stop_lines} && $rule->{stop_lines}{$line_number})
    || ($rule->{stop_regexp} && $line =~ $rule->{stop_regexp});
}

sub print_line {
  my ($plan, $state, $stats, $line, $line_number) = @_;
  $line_number //= $state->{line_number};
  $stats->{lines_selected}++;
  return if $plan->{list_ranges};
  $stats->{lines_printed}++;
  return if $state->{output_sink} && $state->{output_sink}{failed};
  my $filehandle = $state->{output_sink}
    ? $state->{output_sink}{filehandle}
    : \*STDOUT;
  printf {$filehandle} "%5d ", $line_number if ($plan->{number});
  print {$filehandle} $line;
}

sub record_range {
  my ($stats, $file, $start, $end, $rule) = @_;
  return unless defined $start;
  return if $end ne 'EOF' && $start > $end;
  push @{$stats->{ranges}}, {
    end   => $end,
    file  => $file,
    rule  => $rule,
    start => $start,
  };
}

sub empty_captures {
  return {
    named    => {},
    numbered => [],
  };
}

sub match_regexp {
  my ($regexp, $line) = @_;
  return undef unless $regexp;
  return undef unless $line =~ $regexp;

  my @numbered;
  for my $index (1 .. $#-) {
    $numbered[$index] =
      defined $-[$index]
        ? substr($line, $-[$index], $+[$index] - $-[$index])
        : undef;
  }
  my %named = %+;
  return {
    named    => \%named,
    numbered => \@numbered,
  };
}

sub initialize_output_manager {
  my ($plan, $stats) = @_;
  my $has_rule_output =
    grep { defined $_->{output_template} } @{$plan->{rules}};
  my $enabled =
    !$plan->{list_ranges}
    && ($has_rule_output
      || defined $plan->{output_template}
      || defined $plan->{otherwise});
  my $root = File::Spec->rel2abs($plan->{output_dir});
  my %input_paths = map {
    File::Spec->rel2abs($_) => 1
  } grep { $_ ne '-' } @{$plan->{files}};

  my $manager = {
    claimed    => {},
    enabled    => $enabled,
    input_paths => \%input_paths,
    root       => $root,
    sinks      => [],
  };
  return $manager unless $enabled;

  if (!-d $root) {
    eval { make_path($root) };
    if ($@ || !-d $root) {
      runtime_error($stats, "cannot create output directory '$root': $@");
      $manager->{enabled} = 0;
    }
  }
  return $manager;
}

sub output_sink_for_selection {
  my (
    $plan,
    $manager,
    $stats,
    $owner,
    $state,
    $number,
    $rule_name,
  ) = @_;
  return undef unless defined $owner->{output_template};
  return { failed => 1 } unless $manager->{enabled};

  $rule_name //= $owner->{name} // 'default';
  my $relative = expand_output_template(
    $owner->{output_template},
    $owner->{output_dynamic},
    $state,
    $number,
    $rule_name,
    $stats,
  );
  return { failed => 1 } unless defined $relative;

  my $path = File::Spec->catfile(
    $manager->{root},
    File::Spec->splitdir($relative),
  );
  my $dynamic = $owner->{output_dynamic};

  if (my $claimed = $manager->{claimed}{$path}) {
    return $claimed unless $dynamic;
    return $claimed
      if $plan->{append} || $plan->{on_duplicate} eq 'append';
    if ($plan->{on_duplicate} eq 'number') {
      my $suffix = 2;
      my $candidate;
      do {
        $candidate = add_filename_number($path, $suffix++);
      } while ($manager->{claimed}{$candidate} || -e $candidate);
      $path = $candidate;
    } else {
      runtime_error($stats, "duplicate generated output '$path'");
      return { failed => 1 };
    }
  }

  if ($manager->{input_paths}{$path}) {
    runtime_error($stats, "output '$path' is also an input file");
    return { failed => 1 };
  }

  my $parent = dirname($path);
  if (!-d $parent) {
    eval { make_path($parent) };
    if ($@ || !-d $parent) {
      runtime_error($stats, "cannot create output directory '$parent': $@");
      return { failed => 1 };
    }
  }

  my ($filehandle, $temporary_path, $atomic);
  if ($plan->{append}) {
    if (!open($filehandle, '>>', $path)) {
      runtime_error($stats, "cannot append to '$path': $!");
      return { failed => 1 };
    }
    $atomic = 0;
  } else {
    if (-e $path && !$plan->{force}) {
      runtime_error($stats, "output '$path' already exists");
      return { failed => 1 };
    }
    my $ok = eval {
      ($filehandle, $temporary_path) = tempfile(
        '.onoff-XXXXXX',
        DIR    => $parent,
        UNLINK => 0,
      );
      1;
    };
    if (!$ok) {
      runtime_error($stats, "cannot create temporary output for '$path': $@");
      return { failed => 1 };
    }
    $atomic = 1;
  }

  my $sink = {
    atomic         => $atomic,
    filehandle     => $filehandle,
    final_path     => $path,
    temporary_path => $temporary_path,
  };
  $manager->{claimed}{$path} = $sink;
  push @{$manager->{sinks}}, $sink;
  $stats->{output_files}++;
  return $sink;
}

sub expand_output_template {
  my ($template, $dynamic, $state, $number, $rule_name, $stats) = @_;
  return $template unless $dynamic;

  $template =~ s/\$(\d+)/{$1}/g;
  my $expanded = eval {
    $template =~ s/\{([^{}]+)\}/expand_template_token(
      $1,
      $state,
      $number,
      $rule_name,
    )/ge;
    die "unexpanded template field" if $template =~ /[{}]/;
    $template;
  };
  if ($@) {
    my $error = $@;
    chomp $error;
    runtime_error($stats, "cannot expand output template: $error");
    return undef;
  }

  if (!output_name_is_safe($expanded)) {
    runtime_error($stats, "generated output path '$expanded' is unsafe");
    return undef;
  }
  if (length($expanded) > 1024) {
    runtime_error($stats, 'generated output path is too long');
    return undef;
  }
  return $expanded;
}

sub expand_template_token {
  my ($token, $state, $number, $rule_name) = @_;
  if ($token =~ /^number(?::(\d+))?$/) {
    return defined $1 ? sprintf("%0*d", $1, $number) : $number;
  }
  return sanitize_filename_value($state->{filename}) if $token eq 'input';
  return sanitize_filename_value(basename($state->{filename}))
    if $token eq 'input_base';
  return sanitize_filename_value($rule_name) if $token eq 'rule';
  return $state->{line_number} if $token eq 'start_line';
  if ($token =~ /^\d+$/) {
    my $value = $state->{captures}{numbered}[$token];
    die "capture {$token} did not participate" unless defined $value;
    return sanitize_filename_value($value);
  }
  if (exists $state->{captures}{named}{$token}) {
    return sanitize_filename_value($state->{captures}{named}{$token});
  }
  die "unknown template field {$token}";
}

sub sanitize_filename_value {
  my $value = shift;
  $value = '' unless defined $value;
  $value =~ s{[\\/]}{_}g;
  $value =~ s/[\x00-\x1f\x7f]/_/g;
  $value =~ s/[^A-Za-z0-9._-]+/_/g;
  $value =~ s/^\.+/_/;
  $value =~ s/_+/_/g;
  $value = substr($value, 0, 200);
  return length($value) ? $value : 'unnamed';
}

sub output_name_is_safe {
  my $name = shift;
  return 0 unless defined $name && length $name;
  return 0 if File::Spec->file_name_is_absolute($name);
  return 0 if $name =~ /[\x00-\x1f\x7f]/;
  my @parts = File::Spec->splitdir($name);
  return 0 if grep { $_ eq '..' || length($_) > 255 } @parts;
  return 1;
}

sub add_filename_number {
  my ($path, $number) = @_;
  return $path =~ /^(.*?)(\.[^.]*)$/
    ? "${1}_$number$2"
    : "${path}_$number";
}

sub write_otherwise {
  my ($plan, $manager, $stats, $line) = @_;
  return unless defined $plan->{otherwise};
  return if $plan->{list_ranges};
  if (!$manager->{otherwise_sink}) {
    my $owner = {
      name            => 'otherwise',
      output_dynamic  => 0,
      output_template => $plan->{otherwise},
    };
    my $state = {
      captures    => empty_captures(),
      filename    => $manager->{current_file},
      line_number => 0,
    };
    $manager->{otherwise_sink} = output_sink_for_selection(
      $plan,
      $manager,
      $stats,
      $owner,
      $state,
      0,
      'otherwise',
    );
  }
  my $sink = $manager->{otherwise_sink};
  return if !$sink || $sink->{failed};
  print {$sink->{filehandle}} $line;
}

sub finalize_output_manager {
  my ($plan, $manager, $stats) = @_;
  for my $sink (@{$manager->{sinks}}) {
    if (!close($sink->{filehandle})) {
      runtime_error($stats, "cannot close '$sink->{final_path}': $!");
    }
  }

  for my $sink (@{$manager->{sinks}}) {
    next unless $sink->{atomic};
    if ($stats->{errors}) {
      unlink $sink->{temporary_path};
      next;
    }
    if (-e $sink->{final_path} && !$plan->{force}) {
      runtime_error($stats, "output '$sink->{final_path}' appeared during processing");
      unlink $sink->{temporary_path};
      next;
    }
    if (!rename($sink->{temporary_path}, $sink->{final_path})) {
      runtime_error(
        $stats,
        "cannot finalize '$sink->{final_path}': $!",
      );
      unlink $sink->{temporary_path};
    }
  }
}

sub runtime_error {
  my ($stats, $message) = @_;
  warn "onoff: $message\n";
  $stats->{errors}++;
}

sub parse_arguments {
  my $plan = shift;
  my @options = qw(
    ? help debug usage
    regexp find grep
    on start begin start-after
    off stop end end-before
    number lead linger context file rule
    output output-template output-dir otherwise on-duplicate
    append force
    exclude-start exclude-end
    fixed ignore-case list-ranges interactive responses
  );
  @options = map { "-$_" } @options;
  my $abbrev = abbrev @options;
  my @legacy_options = map { "-$_" } qw(
    ? help debug usage
    regexp find grep
    on start begin off stop end
    number lead linger context file
    fixed ignore-case list-ranges interactive
  );
  my $legacy_abbrev = abbrev @legacy_options;
  $abbrev->{$_} = $legacy_abbrev->{$_} for keys %{$legacy_abbrev};
  my %takes_value = map { $_ => 1 } qw(
    -regexp -find -grep
    -on -start -begin -start-after
    -off -stop -end -end-before
    -lead -linger -context -file -rule
    -output -output-template -output-dir -otherwise -on-duplicate -responses
  );

  $plan->{explanations} = [
    { arg => '--help, -help, -?', explanation => 'print detailed help' },
    { arg => '--usage, -usage', explanation => 'print a short usage summary' },
    { arg => '--start, -start', explanation => 'regexp to trigger printing' },
    { arg => '--start-after', explanation => 'start after an excluded matching line' },
    { arg => '--end, -end', explanation => 'regexp to terminate printing' },
    { arg => '--end-before', explanation => 'stop before an excluded matching line' },
    { arg => '--regexp, -regexp', explanation => 'regexp selecting individual lines' },
    { arg => '--rule NAME', explanation => 'begin a named paired range rule' },
    { arg => '--output FILE', explanation => 'route selected ranges to one file' },
    { arg => '--output-template TEMPLATE', explanation => 'derive output filenames from a template' },
    { arg => '--output-dir DIR', explanation => 'confine output files beneath DIR' },
    { arg => '--otherwise FILE', explanation => 'write unselected lines to FILE' },
    { arg => '--append', explanation => 'append to existing output files' },
    { arg => '--force', explanation => 'replace existing output files' },
    { arg => '--on-duplicate POLICY', explanation => 'handle duplicate generated filenames: error, number, or append' },
    { arg => '--exclude-start', explanation => 'exclude the starting boundary' },
    { arg => '--exclude-end', explanation => 'exclude the ending boundary' },
    { arg => '--fixed', explanation => 'treat expressions as literal strings' },
    { arg => '--ignore-case', explanation => 'match without regard to letter case' },
    { arg => '--lead N', explanation => 'print N lines before a trigger' },
    { arg => '--linger N', explanation => 'print N lines after a trigger' },
    { arg => '--context N', explanation => 'print N lines before and after a trigger' },
    { arg => '--number', explanation => 'prefix output with line numbers' },
    { arg => '--list-ranges', explanation => 'list matched ranges without their contents' },
    { arg => '--interactive', explanation => 'review each candidate start boundary' },
    { arg => '--responses FILE', explanation => 'read interactive answers from FILE' },
    { arg => '--file FILE', explanation => 'add an input file' },
    { arg => '--debug', explanation => 'show parsing and processing details' },
    { arg => 'N | N.. | ..M | N..M', explanation => 'select numeric lines or ranges' },
  ];

  my $current_rule;

  while (@ARGV) {
    if ($ARGV[0] eq '--') {
      shift @ARGV;
      push @{$plan->{files}}, splice @ARGV;
      last;
    }

    my $raw_option = $ARGV[0];
    my $lookup = $raw_option;
    $lookup =~ s/^--/-/;
    my $option = $abbrev->{$lookup};

    if ($option) {
      shift @ARGV;
      usage_error("option '$raw_option' requires a value")
        if $takes_value{$option} && !@ARGV;
      my $value = $takes_value{$option} ? shift @ARGV : undef;

      if ($option eq '-help' || $option eq '-?') {
        help($plan);
      } elsif ($option eq '-usage') {
        print "$usage\n";
        exit 0;
      } elsif ($option eq '-debug') {
        $plan->{debug} = 1;
      } elsif ($option eq '-interactive') {
        $plan->{interactive} = 1;
      } elsif ($option eq '-responses') {
        $plan->{responses} = $value;
      } elsif ($option eq '-rule') {
        $current_rule = {
          end_pattern_policies   => {},
          end_patterns           => [],
          include_end            => $plan->{include_end},
          include_start          => $plan->{include_start},
          match_patterns         => [],
          name                   => $value,
          output_dynamic         => $plan->{output_dynamic},
          output_template        => $plan->{output_template},
          start_pattern_policies => {},
          start_patterns         => [],
        };
        push @{$plan->{rules}}, $current_rule;
      } elsif ($option eq '-number') {
        $plan->{number} = 1;
      } elsif ($option eq '-append') {
        $plan->{append} = 1;
      } elsif ($option eq '-force') {
        $plan->{force} = 1;
      } elsif ($option eq '-output-dir') {
        $plan->{output_dir} = $value;
        $plan->{output_dir_set} = 1;
      } elsif ($option eq '-otherwise') {
        $plan->{otherwise} = $value;
      } elsif ($option eq '-on-duplicate') {
        $plan->{on_duplicate} = $value;
      } elsif ($option eq '-output' || $option eq '-output-template') {
        my $owner = $current_rule || $plan;
        $owner->{output_template} = $value;
        $owner->{output_dynamic} =
          $option eq '-output-template' ? 1 : 0;
      } elsif ($option eq '-fixed') {
        $plan->{fixed} = 1;
      } elsif ($option eq '-ignore-case') {
        $plan->{ignore_case} = 1;
      } elsif ($option eq '-exclude-start') {
        if ($current_rule) {
          $current_rule->{include_start} = 0;
        } else {
          $plan->{include_start} = 0;
        }
      } elsif ($option eq '-exclude-end') {
        if ($current_rule) {
          $current_rule->{include_end} = 0;
        } else {
          $plan->{include_end} = 0;
        }
      } elsif ($option eq '-list-ranges') {
        $plan->{list_ranges} = 1;
      } elsif ($option =~ /^-(?:regexp|find|grep)$/) {
        push @{$plan->{match_patterns}}, $value;
      } elsif ($option =~ /^-(?:on|start|begin)$/) {
        my $owner = $current_rule || $plan;
        push @{$owner->{start_patterns}}, $value;
        $owner->{start_pattern_policies}{inclusive} = 1;
      } elsif ($option eq '-start-after') {
        my $owner = $current_rule || $plan;
        push @{$owner->{start_patterns}}, $value;
        $owner->{start_pattern_policies}{exclusive} = 1;
        $owner->{include_start} = 0;
      } elsif ($option =~ /^-(?:off|stop|end)$/) {
        my $owner = $current_rule || $plan;
        push @{$owner->{end_patterns}}, $value;
        $owner->{end_pattern_policies}{inclusive} = 1;
      } elsif ($option eq '-end-before') {
        my $owner = $current_rule || $plan;
        push @{$owner->{end_patterns}}, $value;
        $owner->{end_pattern_policies}{exclusive} = 1;
        $owner->{include_end} = 0;
      } elsif ($option eq '-lead') {
        validate_nonnegative_integer('--lead', $value);
        $plan->{lead} = $value;
      } elsif ($option eq '-linger') {
        validate_nonnegative_integer('--linger', $value);
        $plan->{linger} = $value;
      } elsif ($option eq '-context') {
        validate_nonnegative_integer('--context', $value);
        $plan->{lead} = $value;
        $plan->{linger} = $value;
      } elsif ($option eq '-file') {
        push @{$plan->{files}}, $value;
      }
      next;
    }

    my $argument = shift @ARGV;
    if ($argument =~ m'^-?(\d+)\.\.(\d+)$') {                                    # N to M
      usage_error('line numbers must be greater than zero') if $1 == 0 || $2 == 0;
      usage_error("range start $1 is greater than range end $2") if $1 > $2;
      $plan->{start_lines}{$1}++;
      $plan->{stop_lines}{$2}++;
      print "user has requested printing of lines $1 to $2 inclusive\n" if ($plan->{debug});
    } elsif ($argument =~ m'^-?(\d+)\.\.$') {                                          # N on
      usage_error('line numbers must be greater than zero') if $1 == 0;
      $plan->{start_lines}{$1}++;
      print "user has requested printing of lines starting at $1\n" if ($plan->{debug});
    } elsif ($argument =~ m'^-?\.\.(\d+)$') {                                          #   to M
      usage_error('line numbers must be greater than zero') if $1 == 0;
      $plan->{start_printing} = 1;
      $plan->{stop_lines}{$1}++;
      push( @{$plan->{ranges}}, { start=>undef, end=>$1 } );
      print "user has requested printing of lines up to $1\n" if ($plan->{debug});
    } elsif ($argument =~ m'^-?(\d+)$') {                                              # just print line N
      usage_error('line numbers must be greater than zero') if $1 == 0;
      $plan->{start_lines}{$1}++;
      $plan->{stop_lines}{$1}++;
      print "user has requested printing of line $1\n" if ($plan->{debug});
    } elsif ($argument =~ m'^-?([^.]*)\.\.([^.]*)$') {                                # START to STOP
      my $front=$1;
      my $back=$2;
      if ($front eq '' and $back eq '') {
        usage_error("'..' is not a valid range");
      } elsif ($front eq '') { # ..SOMETHING (not a number)
        print " ..X '$front' '$back'\n" if ($plan->{debug});
        $plan->{start_printing} = 1;
        push @{$plan->{end_patterns}}, $back;
      } elsif ($back eq '') { # SOMETHING.. (not a number)
        print "X..  '$front' '$back'\n" if ($plan->{debug});
        push @{$plan->{start_patterns}}, $front;
      } else {                # SOMETHING..SOMETHING_ELSE (at least one of which is not a number)
        print "X..Y '$front' '$back'\n" if ($plan->{debug});
        if ( $front=~/^\d+$/ ) {
          usage_error('line numbers must be greater than zero') if $front == 0;
          print "N..? '$front' '$back'\n" if ($plan->{debug});
          $plan->{start_lines}{$front}++;
        } else {
          print "X..? '$front' '$back'\n" if ($plan->{debug});
          push @{$plan->{start_patterns}}, $front;
        }
        if ( $back=~/^\d+$/ ) {
          usage_error('line numbers must be greater than zero') if $back == 0;
          print "?..N '$front' '$back'\n" if ($plan->{debug});
          $plan->{stop_lines}{$back}++;
        } else {
          print "?..X '$front' '$back'\n" if ($plan->{debug});
          push @{$plan->{end_patterns}}, $back;
        }
      }
    } else {
      usage_error("unknown option '$argument'")
        if $argument =~ /^-/ && $argument ne '-';
      push @{$plan->{files}}, $argument;
    }
  }

  compile_plan_patterns($plan);

  if ($plan->{debug}) {
    report_plan($plan);
  }
}

sub validate_plan {
  my $plan = shift;
  validate_nonnegative_integer('--lead', $plan->{lead});
  validate_nonnegative_integer('--linger', $plan->{linger});
  usage_error('--responses requires --interactive')
    if defined $plan->{responses} && !$plan->{interactive};
  usage_error('--interactive cannot be combined with --list-ranges')
    if $plan->{interactive} && $plan->{list_ranges};
  usage_error('--append and --force cannot be used together')
    if $plan->{append} && $plan->{force};
  usage_error("--on-duplicate must be 'error', 'number', or 'append'")
    unless $plan->{on_duplicate} =~ /^(?:error|number|append)$/;
  usage_error('--output-dir cannot be empty')
    unless defined $plan->{output_dir} && length $plan->{output_dir};
  validate_output_name('--otherwise', $plan->{otherwise}, 0)
    if defined $plan->{otherwise};
  validate_output_name(
    '--output-template',
    $plan->{output_template},
    $plan->{output_dynamic},
  ) if defined $plan->{output_template};

  my $standard_inputs = grep { $_ eq '-' } @{$plan->{files}};
  usage_error("standard input '-' may only be specified once")
    if $standard_inputs > 1;

  usage_error('mixed start boundary policies require explicit paired rules')
    if keys %{$plan->{start_pattern_policies}} > 1;
  usage_error('mixed end boundary policies require explicit paired rules')
    if keys %{$plan->{end_pattern_policies}} > 1;

  my $has_implicit_range =
    $plan->{start_printing}
    || keys %{$plan->{start_lines}}
    || keys %{$plan->{stop_lines}}
    || @{$plan->{start_patterns}}
    || @{$plan->{end_patterns}};

  my $has_explicit_rules = @{$plan->{rules}} > 0;
  usage_error('cannot mix explicit rules with implicit ranges')
    if $has_explicit_rules && $has_implicit_range;

  if ($has_explicit_rules) {
    my %rule_names;
    for my $rule (@{$plan->{rules}}) {
      usage_error("invalid rule name '$rule->{name}'")
        unless defined $rule->{name}
          && $rule->{name} =~ /^[A-Za-z][A-Za-z0-9_-]*$/;
      usage_error("duplicate rule name '$rule->{name}'")
        if $rule_names{$rule->{name}}++;
      usage_error("rule '$rule->{name}' requires at least one start")
        unless @{$rule->{start_patterns}};
      usage_error("rule '$rule->{name}' requires at least one end")
        unless @{$rule->{end_patterns}};
      usage_error("mixed start boundary policies in rule '$rule->{name}'")
        if keys %{$rule->{start_pattern_policies}} > 1;
      usage_error("mixed end boundary policies in rule '$rule->{name}'")
        if keys %{$rule->{end_pattern_policies}} > 1;
      validate_output_name(
        "output for rule '$rule->{name}'",
        $rule->{output_template},
        $rule->{output_dynamic},
      ) if defined $rule->{output_template};
      usage_error("dynamic output for rule '$rule->{name}' requires --output-dir")
        if $rule->{output_dynamic} && !$plan->{output_dir_set};
    }
  } elsif ($has_implicit_range) {
    push @{$plan->{rules}}, {
      end_patterns   => $plan->{end_patterns},
      include_end    => $plan->{include_end},
      include_start  => $plan->{include_start},
      name           => 'default',
      output_dynamic => $plan->{output_dynamic},
      output_template => $plan->{output_template},
      start_at_beginning => $plan->{start_printing},
      start_lines    => $plan->{start_lines},
      start_patterns => $plan->{start_patterns},
      start_regexp   => $plan->{start_regexp},
      stop_lines     => $plan->{stop_lines},
      stop_regexp    => $plan->{stop_regexp},
    };
  }

  usage_error('dynamic output requires --output-dir')
    if $plan->{output_dynamic}
      && !$plan->{output_dir_set}
      && !$has_explicit_rules;

  $plan->{has_range_conditions} = @{$plan->{rules}} > 0;
  usage_error('--interactive requires a start/end range')
    if $plan->{interactive} && !$plan->{has_range_conditions};
}

sub validate_output_name {
  my ($label, $name, $dynamic) = @_;
  usage_error("$label cannot be empty") unless defined $name && length $name;
  usage_error("$label must be a relative path")
    if File::Spec->file_name_is_absolute($name);
  usage_error("$label contains control characters")
    if $name =~ /[\x00-\x1f\x7f]/;
  my @parts = File::Spec->splitdir($name);
  usage_error("$label cannot contain parent-directory traversal")
    if grep { $_ eq '..' } @parts;
}

sub validate_nonnegative_integer {
  my ($option, $value) = @_;
  usage_error("$option requires a non-negative integer")
    unless defined $value && $value =~ /^\d+$/;
}

sub compile_plan_patterns {
  my $plan = shift;
  compile_pattern_owner($plan, $plan);
  compile_pattern_owner($plan, $_) for @{$plan->{rules}};
}

sub compile_pattern_owner {
  my ($plan, $owner) = @_;
  for my $specification (
    ['start', 'start_patterns', 'start_regexp'],
    ['end',   'end_patterns',   'stop_regexp'],
    ['match', 'match_patterns', 'regexp'],
  ) {
    my ($kind, $patterns_key, $regexp_key) = @{$specification};
    next unless @{$owner->{$patterns_key}};

    my @patterns;
    for my $source (@{$owner->{$patterns_key}}) {
      my $prepared = $plan->{fixed} ? quotemeta($source) : $source;
      compile_regexp($kind, $prepared, $plan->{ignore_case});
      push @patterns, "(?:$prepared)";
    }
    $owner->{$regexp_key} = compile_regexp(
      $kind,
      join('|', @patterns),
      $plan->{ignore_case},
    );
  }
}

sub compile_regexp {
  my ($kind, $source, $ignore_case) = @_;
  my $regexp = eval {
    $ignore_case ? qr/$source/i : qr/$source/
  };
  if (!$regexp || $@) {
    my $error = $@ || 'unknown regular-expression error';
    $error =~ s/\s+at\s+\Q$0\E\s+line\s+\d+.*//s;
    chomp $error;
    usage_error("invalid $kind regular expression '$source': $error");
  }
  return $regexp;
}

sub usage_error {
  my $message = shift;
  warn "onoff: $message\n";
  exit 2;
}

sub help {
  my ($plan,@args) = @_;
  select(STDOUT); $|=1; $\=''; 
  if (@{$plan->{explanations}}) {
    my $width = 0;
    foreach my $explanation (@{$plan->{explanations}}) {
      my $length = length($explanation->{arg});
      $width = $length if $length > $width;
    }
    $width += 2;
    foreach my $explanation ( @{$plan->{explanations}} ) {
      printf "%-*s%s\n",
        $width,
        $explanation->{arg},
        $explanation->{explanation};
    }
  } else {
    for (my $arg=$[; $arg<=$#args; $arg++) {
      print "$args[$arg]\t";
    }
    print "\n";
  }
  exit 0;
}

sub report_plan {
  my $plan = shift;
  print "singles\n";
  print "set regexp to '$plan->{regexp}'\n" if ($plan->{regexp});
  print "starts\n";
  print "set start  to '$plan->{start_regexp}'\n" if ($plan->{start_regexp});
  print "set starts at: " . join(', ', keys %{$plan->{start_lines}}) . "\n" if ($plan->{start_lines});
  print "\nstops\n";
  print "set stop   to '$plan->{stop_regexp}'\n" if ($plan->{stop_regexp});
  print "set stops  at: " . join(', ', keys %{$plan->{stop_lines}}) . "\n" if ($plan->{stop_lines});
  print "include start/end: $plan->{include_start}, $plan->{include_end}\n";
  if (@{$plan->{rules}}) {
    print "\nrules\n";
    for my $rule (@{$plan->{rules}}) {
      print "$rule->{name}: start '$rule->{start_regexp}', ";
      print "end '$rule->{stop_regexp}', ";
      print "include $rule->{include_start}/$rule->{include_end}\n";
      print "  output '$rule->{output_template}'\n"
        if defined $rule->{output_template};
    }
  }
  print "output dir: $plan->{output_dir}\n";
  print "otherwise: $plan->{otherwise}\n" if defined $plan->{otherwise};
  print "\nfiles?\n";
  print "$_\n" foreach (@{$plan->{files}});
  print "lead, linger: $plan->{lead}, $plan->{linger}\n";
  print "=" x 40 . "\n";
}

__END__
